# ============================================================================
# Puls-Events MVP P13 - Variables d'environnement
# Copier vers .env (local) et déclarer dans HF Spaces Settings (déployé)
# ============================================================================

# Mistral La Plateforme - même clé que ton P11
MISTRAL_API_KEY=your_mistral_key_here

# Supabase Postgres Session Pooler (port 5432)
# Format: postgresql+psycopg2://postgres.<projet>:<password>@<host>:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_ID:PASSWORD@aws-1-eu-west-3.pooler.supabase.com:5432/postgres

# Optionnel - taille de la fenêtre de mémoire courte (nb tours)
MEMORY_WINDOW_SIZE=5

# Optionnel - chemin de l'index FAISS (local)
FAISS_INDEX_PATH=data/faiss_index
